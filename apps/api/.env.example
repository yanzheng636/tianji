
ENV=development
PORT=3001
# 前端地址，用于 CORS 白名单（多个用逗号分隔）
WEB_ORIGIN=http://localhost:5173

# ── 数据库 / 缓存（docker compose up -d 起的） ──
DATABASE_URL=
REDIS_URL=redis://localhost:6379

# ── JWT ──
# 生产必须换成随机串：openssl rand -base64 48
JWT_EXPIRES_DAYS=30

# ── 每日额度 ──
# 0 表示求签不限次数；正整数表示所有用户每日最多求签次数
QIAN_DAILY_LIMIT=0

# ── 大模型 Provider（走 OpenAI 协议） ──
# LLM_PROVIDER 可选：mock | deepseek
# mock 无需密钥，返回基于规则的话术，用于本地跑通与 CI
LLM_PROVIDER=deepseek

# DeepSeek（OpenAI 兼容协议）
DEEPSEEK_API_KEY=None
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro


# ── 向量检索（藏经阁 RAG）──
# EMBEDDING_PROVIDER 可选：none | openai
# none 时自动降级为关键词检索，功能仍可用
EMBEDDING_PROVIDER=none
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.deepseek.com
EMBEDDING_MODEL=

# ── 短信验证码 Provider ──
# SMS_PROVIDER 可选：console | aliyun
# console 直接把验证码打到服务端日志，本地开发用
SMS_PROVIDER=console
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
ALIYUN_SMS_REGION_ID=cn-hangzhou
ALIYUN_SMS_ENDPOINT=https://dysmsapi.aliyuncs.com/

# ── 内容审核 Provider（许愿池是 UGC，大陆上线法定必须审）──
# MODERATION_PROVIDER 可选：keyword | aliyun
MODERATION_PROVIDER=keyword
ALIYUN_GREEN_ACCESS_KEY_ID=
ALIYUN_GREEN_ACCESS_KEY_SECRET=

# ── 支付 Provider ──
# PAYMENT_PROVIDER 可选：mock | wechat | alipay
# mock 会在下单后几秒自动回调成功，用于本地跑通支付闭环
# wechat / alipay 需要营业执照申请到的商户号，个人拿不到
PAYMENT_PROVIDER=mock
PAYMENT_NOTIFY_BASE_URL=http://localhost:3001

WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_V3_KEY=
WECHAT_CERT_SERIAL_NO=
WECHAT_PRIVATE_KEY_PATH=

ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
