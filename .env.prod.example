# 复制为根目录 .env.prod，再填写真实值；不要提交 .env.prod。
POSTGRES_USER=tianji
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=tianji
JWT_SECRET=replace-with-openssl-rand-base64-48
WEB_ORIGIN=https://your-domain.example
PAYMENT_NOTIFY_BASE_URL=https://your-domain.example

# 生产短信：阿里云签名和验证码模板必须先审核通过
SMS_PROVIDER=aliyun
ALIYUN_SMS_ACCESS_KEY_ID=replace-me
ALIYUN_SMS_ACCESS_KEY_SECRET=replace-me
ALIYUN_SMS_SIGN_NAME=replace-me
ALIYUN_SMS_TEMPLATE_CODE=SMS_000000000
ALIYUN_SMS_REGION_ID=cn-hangzhou
ALIYUN_SMS_ENDPOINT=https://dysmsapi.aliyuncs.com/

# 生产 AI；若暂不接入对话模型，请先将对应功能关闭，不要用 mock 冒充线上能力
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=replace-me
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 生产必须使用真实审核与支付 provider；其余密钥按业务开通后填写
MODERATION_PROVIDER=aliyun
PAYMENT_PROVIDER=wechat
