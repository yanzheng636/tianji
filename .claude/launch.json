{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--dir", "apps/web", "dev"],
      "port": 5173
    },
    {
      "name": "web-desktop",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--dir", "apps/web-desktop", "dev"],
      "port": 5174
    },
    {
      "name": "api",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "--directory", "apps/api", "uvicorn", "app.main:app", "--port", "3001"],
      "port": 3001
    },
    {
      "name": "api-b",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "--directory", "apps/api", "uvicorn", "app.main:app", "--port", "3021"],
      "port": 3021
    },
    {
      "name": "web-desktop-b",
      "runtimeExecutable": "env",
      "runtimeArgs": ["VITE_API_TARGET=http://127.0.0.1:3021", "pnpm", "--dir", "apps/web-desktop", "dev", "--port", "5194", "--strictPort"],
      "port": 5194
    }
  ]
}
